    "db:migrate": "bun run src/cli/migrate.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.14",
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@disbot/typescript-config": "workspace:*",
    "drizzle-kit": "^0.28.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
